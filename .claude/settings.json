{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$repo_root/.claude/scripts/kanban-sprint-sync.sh\"'",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
